# yn-order-manager API (서버 전용, 클라이언트에 노출 금지)
ORDER_MANAGER_API_URL=http://localhost:3001
ORDER_MANAGER_API_KEY=your_api_key_here

# 관리자 페이지 비밀번호 (필수)
ADMIN_PASSWORD=your_admin_password_here

# Supabase — Vercel 운영 필수
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 서버 전용 (필수). service_role secret — anon key 아님
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 선택. anon key는 현재 서버 CMS에서 직접 사용하지 않지만, 키 혼동 방지용으로 설정 권장
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# 최초 1회: Supabase SQL Editor에서 supabase/schema.sql 실행
# 데이터 이전: npm run migrate:supabase
# 또는 배포 후 관리자 로그인 상태에서 POST /api/admin/migrate
